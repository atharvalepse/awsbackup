    from orchestration.sdp import SDPPipeline


slog = StructuredLogger("server")


# ---------------------------------------------------------------------------
# Request / response models
# ---------------------------------------------------------------------------


class ChatRequest(BaseModel):
    text: str
    target: str = "deepseek"
    session_id: str | None = None
    stream: bool = False  # only meaningful for /chat/stream


class ChatResponse(BaseModel):
    text: str
    session_id: str
    trace_id: str
    target_family: str
    model_version: str
    latency_ms: int
    items_included: int
    query_was_improved: bool
    extracted_memories: int


# ---------------------------------------------------------------------------
# Server state
# ---------------------------------------------------------------------------


class ServerState:
    """Process-wide state. One Pipeline + Store shared across sessions."""

    def __init__(
        self,
        pipeline: Pipeline,
        retriever: SemanticRetriever,
        embedder: Embedder,
        memory_store: JsonlMemoryStore,
        client_factory,
        extractor: MemoryExtractor | None,
        default_target: TargetDescriptor,
        sdp: "SDPPipeline | None" = None,
    ) -> None:
        self.pipeline = pipeline
        self.retriever = retriever
        self.embedder = embedder
        self.memory_store = memory_store
        self.client_factory = client_factory
        self.extractor = extractor
        self.default_target = default_target
        self.sdp = sdp
        self.sessions: dict[str, Conversation] = {}
        self._lock = asyncio.Lock()

    async def get_or_create_conversation(
        self, session_id: str, target: TargetDescriptor
    ) -> Conversation:
        async with self._lock:
            if session_id in self.sessions:
                conv = self.sessions[session_id]
                # Allow target switch mid-session
                if conv.session.target.model_family != target.model_family:
                    conv.session.target = target
                return conv

            async def _ingest(items: list[MemoryItem]) -> None:
                await self.retriever.ingest(items)

            conv = Conversation(
                pipeline=self.pipeline,
                client=self.client_factory(target),
                target=target,
                session_id=session_id,
                extractor=self.extractor,
                memory_store=self.memory_store,
                retriever_ingest=_ingest,
            )
            self.sessions[session_id] = conv
            return conv


_TARGET_BUILDERS = {
    "deepseek": TargetDescriptor.for_deepseek,
    "llama": lambda: TargetDescriptor.for_llama(model_version="llama3.2"),
    "claude": TargetDescriptor.for_claude,
    "gpt": TargetDescriptor.for_chatgpt,
    "gemini": TargetDescriptor.for_gemini,
}


def _resolve_target(name: str) -> TargetDescriptor:
    try:
        return _TARGET_BUILDERS[name]()
    except KeyError as exc:
        raise HTTPException(
            status_code=400,
            detail=f"Unknown target {name!r}. Choices: {sorted(_TARGET_BUILDERS)}",
        ) from exc


# ---------------------------------------------------------------------------
# Pipeline trace — powers /api/memory/trace and /api/memory/recall/stream
# ---------------------------------------------------------------------------


async def stream_pipeline_trace(
    state: "ServerState",
    text: str,
    project_query=None,
    user_id: str | None = None,
) -> "AsyncIterator[tuple[str, dict]]":
    """Run the pipeline stage-by-stage, yielding progress as it goes.

    Yields ``("stage", <stage dict>)`` the instant each stage completes, then
    finally ``("done", <full trace dict>)``. This is what lets the web UI light
    its 7-stage recall indicator from *real* backend progress (SSE) rather than
    a simulated timer. ``run_pipeline_trace`` collects this into the one-shot
    dict used by ``/api/memory/trace``.

    ``project_query`` is an optional ``vector -> (x, y)`` callable (the PCA
    projector) used to place the query in the same 2D space as the memory
    cloud; when omitted the query point is reported as the origin.

    ``user_id`` scopes Postgres retrieval to one tenant's rows (via the
    RLS session var from migration 005). When omitted (admin tools, viz),
    queries run with cross-tenant visibility.
    """
    pipe = state.pipeline
    target = state.default_target
    q = Pipeline.build_query(text=text, target=target, user_id=user_id)

    def ms_since(t0: float) -> int:
        return int((time.perf_counter() - t0) * 1000)

    stages: list[dict] = []

    async def emit(stage: dict) -> dict:
        stages.append(stage)
        return stage

    # [1] Classifier
    t0 = time.perf_counter()
    classification = await pipe.classifier.classify(q)
    yield "stage", await emit({
        "stage": "classifier",
        "name": type(pipe.classifier).__name__,
        "duration_ms": ms_since(t0),
        "output": {
            "intent_type": classification.intent_type,
            "entities": classification.entities,
            "confidence": classification.confidence,
            "source": classification.source.value,
            "degraded": classification.degraded,
        },
    })

    # [2] Embedder
    t0 = time.perf_counter()
    embedded = await pipe.embedder.embed(q, classification)
    norm = math.sqrt(sum(x * x for x in embedded.vector))
    yield "stage", await emit({
        "stage": "embedder",
        "name": embedded.embedder_version,
        "duration_ms": ms_since(t0),
        "output": {
            "dim": len(embedded.vector),
            "l2_norm": norm,
            "first6": [float(x) for x in embedded.vector[:6]],
        },
    })

    qx, qy = project_query(embedded.vector) if project_query else (0.0, 0.0)

    # [3] Retriever probe
    t0 = time.perf_counter()
    probe_hits = await pipe.retriever.search(embedded)
    yield "stage", await emit({
        "stage": "retriever_probe",
        "name": type(pipe.retriever).__name__,
        "duration_ms": ms_since(t0),
        "output": {"hits": len(probe_hits)},
    })

    ranked: list = []
    kept_ids: set = set()
    resolved = None
    if not probe_hits:
        t0 = time.perf_counter()
        resolved = await pipe.sam.reason_from_scratch(q, classification)
        yield "stage", await emit({
            "stage": "sam_reason_from_scratch",
            "name": "SAM",
            "duration_ms": ms_since(t0),
            "output": {
                "improved_query": resolved.improved_query,
                "reasoning": (resolved.reasoning_content or "")[:400],
            },
        })
    else:
        # [4] top-50
        t0 = time.perf_counter()
        top50 = await pipe.retriever.get_top_matches(
            embedded, k=pipe.config.retriever_top_k
        )
        yield "stage", await emit({
            "stage": "retriever_top_k",
            "name": type(pipe.retriever).__name__,
            "duration_ms": ms_since(t0),
            "output": {
                "k": pipe.config.retriever_top_k,
                "returned": len(top50),
                "top": [
                    {"id": h.record.id, "similarity": h.similarity}
                    for h in top50[:10]
                ],
            },
        })

        # [5] Reranker
        t0 = time.perf_counter()
        ranked = await pipe.reranker.pick_best(
            top50, q, k=pipe.config.reranker_top_k
        )
        yield "stage", await emit({
            "stage": "reranker",
            "name": type(pipe.reranker).__name__,
            "duration_ms": ms_since(t0),
            "output": {
                "k": pipe.config.reranker_top_k,
                "returned": len(ranked),
                "ranked": [
                    {
                        "id": h.hit.record.id,
                        "final_score": h.final_score,
                        "semantic": h.semantic_score,
                        "recency": h.recency_score,
                        "authority": h.authority_score,
                        "pin": h.pin_boost,
                    }
                    for h in ranked
                ],
            },
        })

        # [6] SAM — but skip the LLM call when top hits are unambiguous
        t0 = time.perf_counter()
        skip, reason = should_skip_sam(ranked)
        if skip:
            resolved = ResolvedMemorySet(
                kept=ranked,
                superseded=[],
                reason_from_scratch=False,
                notes=[f"SAM skipped: {reason}"],
            )
            yield "stage", await emit({
                "stage": "sam_skipped",
                "name": "SAM (skipped)",
                "duration_ms": ms_since(t0),
                "output": {
                    "reason": reason,
                    "kept": len(ranked),
                    "dropped": 0,
                },
            })
        else:
            resolved = await pipe.sam.resolve_conflicts(q, ranked)
            kept_ids_set = {h.hit.record.id if hasattr(h, "hit") else h.record.id for h in resolved.kept}
            ranked_ids = [h.hit.record.id for h in ranked]
            dropped_ids = [rid for rid in ranked_ids if rid not in kept_ids_set]
            yield "stage", await emit({
                "stage": "sam_resolve_conflicts",
                "name": "SAM",
                "duration_ms": ms_since(t0),
                "output": {
                    "reason": reason,
                    "kept": len(resolved.kept),
                    "dropped": len(dropped_ids),
                    "dropped_ids": dropped_ids,
                    "superseded": resolved.superseded,
                    "improved_query": resolved.improved_query,
                    "reasoning": (resolved.reasoning_content or "")[:600],
                },
            })
        kept_ids = {h.hit.record.id if hasattr(h, "hit") else h.record.id for h in resolved.kept}

    # [7] Assembler
    tokenizer, assembler, template_overhead = pipe._resolve_target(target)
    t0 = time.perf_counter()
    context = assembler.package(
        resolved, q, template_overhead_tokens=template_overhead,
        final=pipe.config.assembler_final_k,
    )
    assembled_ids = [h.hit.record.id for h in context.selected]
    yield "stage", await emit({
        "stage": "assembler",
        "name": type(assembler).__name__,
        "duration_ms": ms_since(t0),
        "output": {
            "selected": len(context.selected),
            "selected_ids": assembled_ids,
            "dropped_budget": len(context.dropped_ids),
            "budget_total": context.budget_total,
            "budget_used": context.budget_total - context.budget_remaining,
        },
    })

    # [8] Translator
    t0 = time.perf_counter()
    payload = pipe.translator.translate(context, config_hash=pipe._config_hash)
    yield "stage", await emit({
        "stage": "translator",
        "name": "Translator",
        "duration_ms": ms_since(t0),
        "output": {
            "formatted_chars": len(payload.formatted_context),
            "user_query": payload.user_query,
            "items_included": payload.metadata.get("items_included"),
        },
    })

    # Per-memory annotations the frontend uses for coloring
    retrieved_ids = {h.record.id for h in probe_hits}

    yield "done", {
        "query": {"text": text, "x": qx, "y": qy},
        "stages": stages,
        "annotations": {
            "retrieved_ids": sorted(retrieved_ids),
            "ranked": [
                {"id": h.hit.record.id, "final_score": h.final_score}
                for h in ranked
            ],
            "sam_kept_ids": sorted(kept_ids),
            "assembled_ids": assembled_ids,
            "improved_query": (resolved.improved_query if resolved else None),
            "sam_reasoning": ((resolved.reasoning_content or "")[:1200] if resolved else None),
        },
        "formatted_context": payload.formatted_context,
    }


async def run_pipeline_trace(
    state: "ServerState",
    text: str,
    project_query=None,
    user_id: str | None = None,
) -> dict:
    """One-shot collector over :func:`stream_pipeline_trace`.

    Single source of truth for the web UI's ``/api/memory/trace`` view —
    returns the full trace dict once the pipeline has run end to end.
    ``user_id`` propagates through to RLS scoping.
    """
    final: dict = {}
    async for kind, payload in stream_pipeline_trace(
        state, text, project_query, user_id=user_id,
    ):
        if kind == "done":
            final = payload
    return final


# ---------------------------------------------------------------------------
# FastAPI app factory
# ---------------------------------------------------------------------------


def _inmemory_record_count(retriever) -> int:
    """Count of records held in the in-memory retriever cache, or 0.

    JSONL backend wraps a SemanticRetriever (exposes ``.records``) inside a
    HybridRetriever (does not), so we check the wrapper then its ``.dense``.
    Postgres-backed retrievers keep no in-memory mirror — returns 0 (the
    authoritative count is /api/health's SELECT count(*))."""
    recs = getattr(retriever, "records", None)
    if recs is None:
        recs = getattr(getattr(retriever, "dense", None), "records", None)
    return len(recs) if recs is not None else 0


def build_app(
    state: ServerState,
    *,
    on_startup: "Callable[[], Awaitable[None]] | None" = None,
    on_shutdown: "Callable[[], Awaitable[None]] | None" = None,
) -> FastAPI:
    _bg_tasks: set = set()

    async def _warm_reranker() -> None:
        """Force the cross-encoder model to load at startup, so the FIRST
        /memory/recall after a (re)start doesn't pay the lazy model-load cost
        — which on CPU can exceed the extension's 15s recall timeout. Runs in
        the background; best-effort, never blocks serving."""
        try:
            from datetime import datetime, timezone
            from orchestration.pipeline.contracts import Query, RetrievalHit
            reranker = getattr(state.pipeline, "reranker", None)
            if reranker is None:
                return
            item = MemoryItem(
                id="__warm__", content="warmup", source="warm",
                authority_score=0.5, timestamp=datetime.now(timezone.utc),
            )
            q = Query(text="warmup", target=state.default_target, trace_id="warm")
            await reranker.pick_best(
                [RetrievalHit(record=item, similarity=0.5)], q, k=1
            )
            slog.info(event="reranker_warmed")
        except Exception as exc:  # best-effort — never block serving
            slog.warning(
                event="reranker_warm_failed",
                error_type=type(exc).__name__, error=str(exc),
            )

    @asynccontextmanager
    async def lifespan(app: FastAPI) -> AsyncIterator[None]:
        slog.info(event="server_starting", version=__version__)
        # Async init that must run on the serving event loop — notably the
        # asyncpg pool. Used by the make_app() factory; None for the gml-serve
        # path, which builds the state before calling build_app.
        if on_startup is not None:
            await on_startup()
        # Pre-warm the cross-encoder reranker in the background so the first
        # recall after a restart is fast (avoids the 15s extension timeout).
        _warm = asyncio.create_task(_warm_reranker())
        _bg_tasks.add(_warm)
        _warm.add_done_callback(_bg_tasks.discard)
        try:
            yield
        finally:
            if on_shutdown is not None:
                await on_shutdown()
            try:
                n_sessions = len(state.sessions)
            except Exception:
                n_sessions = 0  # state may be a not-yet-initialized proxy
            slog.info(event="server_stopping", sessions=n_sessions)

    app = FastAPI(
        title="GML Memory Orchestration",
        version=__version__,
        lifespan=lifespan,
    )

    # CORS — env-configurable allowlist. Defaults cover the standard dev
    # frontend ports (Next.js, Vite). Override for prod via GML_CORS_ORIGINS.
    # Wildcards are NOT permitted when allow_credentials=True (browser spec).
    _default_origins = (
        "http://localhost:3000,http://localhost:5173,"
        "http://127.0.0.1:3000,http://127.0.0.1:5173"
    )
    _origins_raw = os.environ.get("GML_CORS_ORIGINS", _default_origins).strip()
    cors_origins = [o.strip() for o in _origins_raw.split(",") if o.strip()]
    app.add_middleware(
        CORSMiddleware,
        allow_origins=cors_origins,
        allow_credentials=True,
        allow_methods=["GET", "POST", "DELETE", "OPTIONS"],
        allow_headers=["Content-Type", "Authorization", "X-API-Key"],
    )
    slog.info(event="cors_configured", origins=cors_origins)

    # API key auth — optional. Two layers stack:
    #   1. GML_API_KEY: master/admin key. Required to issue per-user keys.
    #   2. Per-user keys (JSONL or Postgres via the storage factory).
    # A request authenticates if EITHER the master key matches, OR the
    # header value is found in the user store. Public paths skip both.
    # Auth is ON whenever GML_API_KEY is set OR GML_STORAGE_BACKEND=postgres
    # (in production mode you should never be running open).
    from orchestration.storage import make_user_key_store, _is_postgres
    from orchestration.auth import (
        JWTError, decode_access_token, hash_password, make_access_token, verify_password,
    )
    from orchestration.auth.tokens import looks_like_jwt
    api_key = os.environ.get("GML_API_KEY", "").strip()
    auth_enabled = bool(api_key) or _is_postgres()
    public_paths = {
        "/", "/health", "/metrics", "/api/health",
        "/docs", "/openapi.json", "/redoc",
        "/auth/signup", "/auth/login",   # self-service auth — no token yet
        "/auth/logout",                  # clearing a cookie shouldn't require auth
    }
    # Admin-only paths — even with a valid user key these reject (only the
    # master GML_API_KEY can issue/list/revoke other users' keys).
    admin_paths = {"/api/admin/keys", "/api/admin/users"}

    # User store is built lazily on first request (so we don't hit the DB
    # at import time, which would break tests + dev). Cache the instance.
    _user_store_cache: dict = {"instance": None}

    async def _user_store():
        if _user_store_cache["instance"] is None:
            _user_store_cache["instance"] = await make_user_key_store()
        return _user_store_cache["instance"]

    if auth_enabled:
        slog.info(
            event="api_key_auth_enabled",
            backend=os.environ.get("GML_STORAGE_BACKEND", "jsonl"),
            public_paths=sorted(public_paths),
        )

        @app.middleware("http")
        async def _api_key_middleware(request: Request, call_next):
            path = request.url.path
            if request.method == "OPTIONS":
                return await call_next(request)
            if path in public_paths or path.startswith("/static/"):
                return await call_next(request)
            provided = request.headers.get("X-API-Key") or ""
            if not provided:
                auth = request.headers.get("Authorization") or ""
                if auth.lower().startswith("bearer "):
                    provided = auth.split(None, 1)[1].strip()
            # Cookie fallback for browser navigation (e.g. <a href> downloads
            # of /api/me/install/*) where JS can't attach an Authorization
            # header. Login / signup also set this cookie alongside returning
            # the access_token in the JSON body, so existing Bearer consumers
            # keep working unchanged. SameSite=Lax means top-level navigations
            # send it but cross-site sub-resource requests don't.
            if not provided:
                provided = request.cookies.get("gml_session", "") or ""
            # Constant-time compare so the master key can't be recovered via a
            # timing side-channel.
            is_master = bool(api_key) and hmac.compare_digest(provided, api_key)
            resolved_user_id = None
            if not is_master and provided:
                # A JWT (from /auth/login) and an API key are both bearer-able.
                # Try JWT first when it has the right shape, else key lookup.
                if looks_like_jwt(provided):
                    try:
                        resolved_user_id = decode_access_token(provided)
                    except JWTError:
                        resolved_user_id = None
                if resolved_user_id is None:
                    store = await _user_store()
                    rec = await store.lookup(provided)
                    resolved_user_id = rec.user_id if rec else None
            if not is_master and resolved_user_id is None:
                return Response(
                    content='{"detail":"unauthorized"}',
                    status_code=401,
                    media_type="application/json",
                )
            # Master-key callers may act on behalf of a tenant — the MCP
            # stdio proxy forwards its GML_MCP_USER this way so per-session
            # scoping survives the hop. The request then counts as that
            # user, NOT as master (admin routes reject it below). Per-user
            # keys naming someone else are rejected loudly rather than
            # silently writing into the key's own tenant.
            act_as = (request.headers.get("X-GML-Act-As") or "").strip()
            if act_as:
                if not is_master:
                    return Response(
                        content='{"detail":"X-GML-Act-As requires the master key"}',
                        status_code=403,
                        media_type="application/json",
                    )
                is_master = False
                resolved_user_id = act_as[:128]
            # Admin-only routes require the master key.
            if path in admin_paths and not is_master:
                return Response(
                    content='{"detail":"admin only"}',
                    status_code=403,
                    media_type="application/json",
                )
            # Attach auth context for downstream handlers.
            request.state.user_id = "admin" if is_master else resolved_user_id
            request.state.is_master = is_master
            return await call_next(request)
    else:
        slog.warning(
            event="api_key_auth_disabled",
            note="GML_API_KEY unset and storage=jsonl; "
            "ALL endpoints are publicly reachable.",
        )

    # ----- Admin endpoints (master-key only) -----

    class _IssueKeyRequest(BaseModel):
        user_id: str = Field(min_length=1, max_length=128)
        label: str | None = Field(default=None, max_length=128)

    @app.post("/api/admin/keys")
    async def admin_issue_key(req: _IssueKeyRequest) -> dict:
        """Issue a new per-user API key. Returns the secret ONCE; store it."""
        store = await _user_store()
        rec = await store.issue(req.user_id, label=req.label)
        return {
            "key": rec.key,
            "user_id": rec.user_id,
            "created_at": rec.created_at,
            "label": rec.label,
            "note": "Store this key — it is not retrievable later.",
        }

    @app.get("/api/admin/keys")
    async def admin_list_keys() -> dict:
        """List all per-user keys (key values are redacted)."""
        store = await _user_store()
        users = await store.list_users()
        return {
            "count": len(users),
            "users": [u.to_public_dict() for u in users],
        }

    @app.delete("/api/admin/keys")
    async def admin_revoke_key(key: str = Query(min_length=1)) -> dict:
        """Revoke a key by its full value (provide as ?key=<full>)."""
        store = await _user_store()
        ok = await store.revoke(key)
        if not ok:
            raise HTTPException(status_code=404, detail="key not found")
        return {"revoked": True}

    # ----- Self-service per-user keys (caller manages their OWN keys) -----
    # Authed by the caller's own token (JWT or user key). The master/admin
    # caller is rejected here — admins use /api/admin/keys above. Every route
    # is scoped to request.state.user_id so a user can only see/revoke keys
    # that belong to them.

    def _require_user(request: Request) -> str:
        uid = getattr(request.state, "user_id", None)
        if getattr(request.state, "is_master", False) or uid in (None, "", "admin"):
            raise HTTPException(
                status_code=403,
                detail="self-service key management requires a user token",
            )
        return uid

    class _MeIssueKeyRequest(BaseModel):
        label: str | None = Field(default=None, max_length=128)

    @app.post("/api/me/keys")
    async def me_issue_key(req: _MeIssueKeyRequest, request: Request) -> dict:
        """Issue a new key for the calling user. Returns the secret ONCE."""
        uid = _require_user(request)
        store = await _user_store()
        rec = await store.issue(uid, label=req.label)
        return {
            "key": rec.key,
            "user_id": rec.user_id,
            "created_at": rec.created_at,
            "label": rec.label,
            "note": "Store this key — it is not retrievable later.",
        }

    @app.get("/api/me/keys")
    async def me_list_keys(request: Request) -> dict:
        """List the calling user's own keys (key values are redacted)."""
        uid = _require_user(request)
        store = await _user_store()
        keys = [rec.to_public_dict() async for rec in store.by_user_id(uid)]
        return {"count": len(keys), "keys": keys}

    @app.delete("/api/me/keys")
    async def me_revoke_key(request: Request, key: str = Query(min_length=1)) -> dict:
        """Revoke one of the caller's own keys.

        ``key`` may be the full secret (what a client still holds) or the
        redacted ``key_preview`` from GET /api/me/keys — so a user can revoke a
        key they no longer have in full straight from the listing. Either form
        is resolved ONLY against the caller's own keys.
        """
        uid = _require_user(request)
        store = await _user_store()
        rec = await store.lookup(key)
        if rec is not None:
            if rec.user_id != uid:
                raise HTTPException(status_code=403, detail="not your key")
            await store.revoke(key)
            return {"revoked": True}
        # Not a full key we hold — match the caller's own keys by their preview.
        # Drain the generator FULLY first: the JSONL store holds an internal
        # lock while iterating, and revoke() runs on a worker thread — revoking
        # mid-iteration would deadlock on that lock.
        own = [rec async for rec in store.by_user_id(uid)]
        target = next(
            (r.key for r in own if r.to_public_dict()["key_preview"] == key), None
        )
        if target is None:
            raise HTTPException(status_code=404, detail="key not found")
        await store.revoke(target)
        return {"revoked": True}

    # ----- Email + password auth (self-service; issues JWTs) -----
    # signup/login are public (no token yet); /auth/me needs a valid token.
    # Requires the Postgres backend (the JSONL key store has no passwords).

    class _SignupRequest(BaseModel):
        email: str = Field(min_length=3, max_length=254)
        password: str = Field(min_length=8, max_length=256)
        invite_code: str = Field(min_length=3, max_length=32)

    class _LoginRequest(BaseModel):
        email: str = Field(min_length=3, max_length=254)
        password: str = Field(min_length=1, max_length=256)

    def _norm_email(e: str) -> str:
        return e.strip().lower()

    _DISPOSABLE = {
        "mailinator.com","guerrillamail.com","throwam.com","trashmail.com",
        "yopmail.com","sharklasers.com","guerrillamailblock.com","grr.la",
        "guerrillamail.info","guerrillamail.biz","guerrillamail.de",
        "guerrillamail.net","guerrillamail.org","spam4.me","dispostable.com",
        "mailnull.com","maildrop.cc","discard.email","tempmail.com",
        "temp-mail.org","fakeinbox.com","getnada.com","mailnesia.com",
        "tempr.email","DiscardMail.com","spamgourmet.com","spamgourmet.net",
        "throwam.com","throwam.net","byom.de","spamherelots.com",
    }

    def _valid_email(e: str) -> bool:
        if "@" not in e or " " in e:
            return False
        _, domain = e.rsplit("@", 1)
        if "." not in domain:
            return False
        if domain.lower() in _DISPOSABLE:
            return False
        return True

    def _set_session_cookie(response: Response, tok: dict) -> None:
        """Attach the access token as a cookie alongside the JSON response.

        Why both? The existing dashboard reads ``access_token`` from JSON and
        keeps it in localStorage, adding ``Authorization: Bearer ...`` to
        every fetch. That works for XHR / fetch but NOT for browser
        navigation (e.g. clicking <a href="/api/me/install/nuts-windows">)
        where there's no JS hook to attach the header. The cookie covers
        that gap. SameSite=Lax stops cross-site CSRF; HttpOnly stops the
        cookie from being read by JS (defense in depth - the token is also
        in localStorage but the cookie can't leak via XSS console).
        """
        response.set_cookie(
            key="gml_session",
            value=tok["access_token"],
            max_age=int(tok["expires_in"]),
            httponly=True,
            secure=True,
            samesite="lax",
            path="/",
        )


    # ── Admin: invite code management ────────────────────────────────────
    # These endpoints require plan='admin' — checked inside each handler.

    async def _require_admin(request: Request):
        """Return user record if authenticated as admin, else raise 403."""
        user = getattr(request.state, "user", None)
        if user is None:
            raise HTTPException(status_code=401, detail="authentication required")
        store = await _user_store()
        profile = await store.get_user(user.user_id) if hasattr(store, "get_user") else None
        if not profile or profile.get("plan") != "admin":
            raise HTTPException(status_code=403, detail="admin access required")
        return profile

    @app.post("/api/admin/invite-codes")
    async def admin_create_invite(request: Request) -> dict:
        """Generate a new invite code. Admin only."""
        await _require_admin(request)
        store = await _user_store()
        user = request.state.user
        code = await store.generate_invite_code(created_by=user.user_id)
        slog.info(event="invite_code_created", code=code, by=user.user_id)
        return {"code": code}

    @app.get("/api/admin/invite-codes")
    async def admin_list_invites(request: Request) -> dict:
        """List all invite codes. Admin only."""
        await _require_admin(request)
        store = await _user_store()
        codes = await store.list_invite_codes()
        # Serialize datetimes
        import datetime as _dt
        result = []
        for row in codes:
            result.append({
                "code": row["code"],
                "created_by": row["created_by"],
                "created_at": row["created_at"].isoformat() if isinstance(row["created_at"], _dt.datetime) else str(row["created_at"]),
                "used_by_email": row["used_by_email"],
                "used_at": row["used_at"].isoformat() if row["used_at"] and isinstance(row["used_at"], _dt.datetime) else (str(row["used_at"]) if row["used_at"] else None),
                "expires_at": row["expires_at"].isoformat() if row["expires_at"] and isinstance(row["expires_at"], _dt.datetime) else None,
            })
        return {"codes": result, "total": len(result)}

    @app.get("/api/admin/users")
    async def admin_list_users_v2(request: Request) -> dict:
        """List all users with email + plan. Admin only."""
        await _require_admin(request)
        store = await _user_store()
        if not hasattr(store, "list_all_users_full"):
            # Fallback to existing list_users
            users = await store.list_users()
            return {"users": [{"user_id": u.user_id, "created_at": u.created_at} for u in users]}
        users = await store.list_all_users_full()
        return {"users": users}


    @app.post("/auth/signup")
    async def auth_signup(req: _SignupRequest, response: Response) -> dict:
        store = await _user_store()
        if not hasattr(store, "create_user_with_password"):
            raise HTTPException(
                status_code=501,
                detail="email/password auth requires the Postgres backend",
            )
        email = _norm_email(req.email)
        if not _valid_email(email):
            raise HTTPException(status_code=422, detail="invalid email address")
        # Validate invite code before creating the user
        if not hasattr(store, "validate_and_use_invite_code"):
            raise HTTPException(
                status_code=501, detail="invite code validation requires Postgres backend"
            )
        code_ok = await store.validate_and_use_invite_code(req.invite_code.strip().upper(), email)
        if not code_ok:
            raise HTTPException(
                status_code=400,
                detail="invite code is invalid, already used, or expired",
            )
        import secrets as _secrets
        user_id = "usr_" + _secrets.token_hex(8)
        created = await store.create_user_with_password(
            user_id, email, hash_password(req.password)
        )
        if not created:
            raise HTTPException(
                status_code=409, detail="an account with that email already exists"
            )
        slog.info(event="auth_signup", user_id=user_id)
        tok = make_access_token(user_id)
        _set_session_cookie(response, tok)
        return tok

    @app.post("/auth/login")
    async def auth_login(req: _LoginRequest, response: Response) -> dict:
        store = await _user_store()
        if not hasattr(store, "get_user_auth_by_email"):
            raise HTTPException(
                status_code=501,
                detail="email/password auth requires the Postgres backend",
            )
        row = await store.get_user_auth_by_email(_norm_email(req.email))
        if (
            row is None
            or not row.get("is_active", True)
            or not verify_password(req.password, row.get("password_hash"))
        ):
            raise HTTPException(status_code=401, detail="invalid email or password")
        slog.info(event="auth_login", user_id=row["user_id"])
        tok = make_access_token(row["user_id"])
        _set_session_cookie(response, tok)
        return tok

    @app.post("/auth/logout")
    async def auth_logout(response: Response) -> dict:
        """Clear the session cookie so subsequent browser-navigation requests
        re-prompt for sign-in. The dashboard also clears localStorage on its
        side; this endpoint is the cookie counterpart."""
        response.delete_cookie(key="gml_session", path="/")
        return {"ok": True}

    @app.get("/auth/me")
    async def auth_me(request: Request, response: Response) -> dict:
        uid = getattr(request.state, "user_id", None)
        if not uid:
            raise HTTPException(status_code=401, detail="unauthorized")
        is_master = getattr(request.state, "is_master", False)
        email = None
        store = await _user_store()
        if not is_master and hasattr(store, "get_user"):
            u = await store.get_user(uid)
            email = u.get("email") if u else None
        # Self-healing cookie: if the caller was authenticated by Bearer
        # header but doesn't yet have the gml_session cookie (e.g. they
        # signed in before cookie auth shipped), set it now. Idempotent.
        if not is_master and not request.cookies.get("gml_session"):
            _set_session_cookie(response, make_access_token(uid))
        return {"user_id": uid, "email": email, "is_master": is_master}

    app.state.server_state = state  # type: ignore[attr-defined]

    # /api/* routes for the web UI. Lives in orchestration/api_routes.py;
    # we inject ``run_pipeline_trace`` here to avoid a circular import.
    from orchestration.api_routes import build_api_router
    app.include_router(build_api_router(state, run_trace=run_pipeline_trace))

    @app.get("/health")
    def health() -> dict:
        return {
            "status": "ok",
            "version": __version__,
            "sessions": len(state.sessions),
            "memories_loaded": _inmemory_record_count(state.retriever),
            "embedder": state.embedder.version,
        }

    @app.get("/metrics")
    def metrics() -> Response:
        return Response(
            content=CounterRegistry.get().render_prometheus(),
            media_type="text/plain; version=0.0.4",
        )

    @app.post("/chat", response_model=ChatResponse)
    async def chat(req: ChatRequest) -> ChatResponse:
        session_id = req.session_id or uuid.uuid4().hex
        target = _resolve_target(req.target)
        conv = await state.get_or_create_conversation(session_id, target)
        try:
            result = await conv.ask(req.text)
        except Exception as exc:
            slog.error(
                event="chat_failed",
                session_id=session_id,
                error_type=type(exc).__name__,
                error=str(exc),
            )
            raise HTTPException(
                status_code=500, detail=f"{type(exc).__name__}: {exc}"
            ) from exc
        return ChatResponse(
            text=result.response.text,
            session_id=session_id,
            trace_id=result.payload.trace_id,
            target_family=target.model_family.value,
            model_version=result.response.model_version,
            latency_ms=result.response.latency_ms,
            items_included=result.payload.metadata.get("items_included", 0),
            query_was_improved=result.payload.metadata.get("query_was_improved", False),
            extracted_memories=len(result.extracted_memories),
        )

    @app.post("/chat/stream")
    async def chat_stream(req: ChatRequest) -> StreamingResponse:
        session_id = req.session_id or uuid.uuid4().hex
        target = _resolve_target(req.target)
        conv = await state.get_or_create_conversation(session_id, target)

        async def _gen() -> AsyncIterator[bytes]:
            # We don't yet stream from the underlying clients, so we yield
            # the full result as a single event after computing it. Stream
            # endpoint exists for future token-level streaming.
            try:
                result = await conv.ask(req.text)
            except Exception as exc:
                payload = (
                    f'event: error\ndata: {type(exc).__name__}: {exc}\n\n'
                )
                yield payload.encode("utf-8")
                return
            yield f'event: meta\ndata: {{"session_id": "{session_id}", "trace_id": "{result.payload.trace_id}"}}\n\n'.encode("utf-8")
            yield f'event: token\ndata: {result.response.text}\n\n'.encode("utf-8")
            yield b"event: done\ndata: \n\n"

        return StreamingResponse(_gen(), media_type="text/event-stream")

    # The legacy unscoped GET/POST /memories endpoints were removed: they
    # read and wrote the store without a user_id, which under the Postgres
    # backend bypassed per-tenant RLS scoping. Use /api/memories instead.

    @app.get("/sessions")
    def list_sessions() -> dict:
        return {
            "count": len(state.sessions),
            "sessions": [
                {
                    "session_id": sid,
                    "target": conv.session.target.model_family.value,
                    "turns": len(conv.session.turns),
                }
                for sid, conv in state.sessions.items()
            ],
        }

    @app.get("/")
    def root() -> dict:
        return {
            "service": "gml-orchestration",
            "version": __version__,
            "endpoints": [
                "POST /chat", "POST /chat/stream",
                "GET /sessions", "GET /health", "GET /metrics",
                "GET /api/health",
                "GET /api/memories", "POST /api/memories",
                "GET /api/memories/{id}",
                "GET /api/memories/graph", "DELETE /api/memories/{id}",
                "GET /api/clusters",
                "POST /api/memory/recall", "POST /api/memory/ingest",
                "POST /api/memory/sdp_ingest", "POST /api/memory/trace",
                "GET /api/memory/synthesize",
            ],
        }

    # Visualization lives entirely in the Next.js dashboard (akhrots.com/app:
    # graph + memory list + recall, /app/trace: pipeline trace). The server
    # exposes no HTML viz pages of its own — only the /api/* data the
    # dashboard reads (per-user, RLS-scoped). One visualization surface.

    # ---- /api: stable contract for the Next.js web UI ----------------
    from orchestration.api_routes import build_api_router

    app.include_router(
        build_api_router(
            state,
            run_trace=lambda st, text, user_id=None:
                run_pipeline_trace(st, text, user_id=user_id),
        )
    )

    return app


# ---------------------------------------------------------------------------
# Default-state builder — used by the CLI when launching `gml serve`
# ---------------------------------------------------------------------------


async def build_default_state(
    *,
    embedder: Embedder,
    memory_path: Path,
    enable_sam_llm: bool = True,
    default_target_name: str = "deepseek",
    stub_client: bool = False,
) -> ServerState:
    """Construct a ServerState with sane defaults — used by ``gml serve``."""
    from orchestration.retriever import default_records

    config = load_config(Path(__file__).resolve().parent.parent / "config" / "orchestration.toml")

    # Storage + retriever backends are picked by GML_STORAGE_BACKEND.
    # JSONL: in-memory SemanticRetriever wrapped with BM25 in HybridRetriever,
    #        seeded from the JSONL store at startup.
    # Postgres: PgvectorSemanticRetriever + PgvectorBM25Retriever in
    #        HybridRetriever — they query the DB on every request, no
    #        startup ingest needed (and indeed nothing to ingest since
    #        Postgres holds the source of truth).
    from orchestration.storage import _is_postgres, make_hybrid_retriever, make_memory_store
    retriever = await make_hybrid_retriever(embedder)
    store = await make_memory_store(
        fallback_jsonl_path=memory_path, embedder=embedder
    )

    if not _is_postgres():
        # JSONL path: load persisted memories (or default fixture) into the
        # in-memory retriever so it can serve requests. The Postgres path
        # skips this because the retriever queries the DB directly.
        persisted = await store.load_all()
        if persisted:
            await retriever.ingest(persisted)
        else:
            await retriever.ingest(default_records())

    sam = SAM.with_ollama() if enable_sam_llm else SAM(reasoner=None)
    pipeline = Pipeline(
        classifier=KeywordClassifier(),
        embedder=embedder,
        retriever=retriever,
        reranker=make_reranker(config),
        sam=sam,
        translator=Translator(),
        config=config,
    )

    def _client_factory(target: TargetDescriptor) -> Client:
        if stub_client:
            return StubClient()
        return build_default_client_for_target(target)

    # Extraction runs in the background (see api_routes ingest), so give the
    # slow local CPU model a generous timeout rather than the 90s default —
    # nothing is waiting on it interactively.
    extractor = (
        MemoryExtractor(client=make_local_llm_client(timeout_seconds=300.0))
        if enable_sam_llm
        else None
    )

    # SDP is LLM-free (regex-based), so it's always available — it powers the
    # fast /api/memory/sdp_ingest path regardless of Ollama.
    from orchestration.sdp import SDPPipeline

    sdp = SDPPipeline(source_tag="sdp")

    return ServerState(
        pipeline=pipeline,
        retriever=retriever,
        embedder=embedder,
        memory_store=store,
        client_factory=_client_factory,
        extractor=extractor,
        default_target=_resolve_target(default_target_name),
        sdp=sdp,
    )


def _build_embedder_from_env() -> Embedder:
    """Pick the factory's embedder from ``GML_EMBEDDER`` (default FastEmbed —
    local, no API key). Mirrors the intent of ``gml serve``'s autodetect."""
    choice = os.environ.get("GML_EMBEDDER", "fastembed").strip().lower()
    from orchestration.embedder import (
        FastEmbedEmbedder, GeminiEmbedder, OllamaEmbedder, StubEmbedder,
    )
    if choice == "stub":
        return StubEmbedder(dim=384)
    if choice == "st":
        # Local sentence-transformers model (e.g. the FT'd embedder at
        # GML_ST_EMBED_MODEL). Requires torch + sentence-transformers.
        from orchestration.embedder import SentenceTransformerEmbedder
        return SentenceTransformerEmbedder(device=os.environ.get("GML_ST_DEVICE", "cpu"))
    if choice == "ollama":
        return OllamaEmbedder()
    if choice == "gemini":
        return GeminiEmbedder()
    return FastEmbedEmbedder()


class _DeferredServerState:
    """Stand-in for the ServerState that the lifespan builds on startup.

    The uvicorn factory can't build the state synchronously: it's async and,
    on the Postgres backend, opens an asyncpg pool that must live on uvicorn's
    event loop (building it under a throwaway ``asyncio.run`` loop would leave
    the pool bound to a loop that's already closed). So ``make_app`` returns
    the app immediately with this proxy in place of the state; the lifespan
    builds the real state on the serving loop and drops it into ``holder``.
    Routes read ``state.<attr>`` only at request time — after startup — so they
    transparently reach the real object.
    """
    __slots__ = ("_holder",)

    def __init__(self, holder: dict) -> None:
        object.__setattr__(self, "_holder", holder)

    def __getattr__(self, name: str):
        real = object.__getattribute__(self, "_holder").get("state")
        if real is None:
            raise RuntimeError(
                "ServerState not initialized yet — the server is still "
                "starting (lifespan startup hasn't completed)."
            )
        return getattr(real, name)


def make_app() -> FastAPI:
    """Uvicorn factory: ``uvicorn orchestration.server:make_app --factory``.

    Builds the FastAPI app from env vars. The async initialization
    (``build_default_state`` — store, retriever, and the asyncpg pool on the
    Postgres backend) runs in the lifespan's startup hook so it binds to
    uvicorn's running event loop; ``close_pg_pool`` runs on shutdown.

    Env: ``GML_EMBEDDER`` (default ``fastembed``), ``GML_MEMORY_STORE_PATH``,
    ``GML_ENABLE_SAM_LLM`` (``0`` to disable), ``GML_DEFAULT_TARGET``,
    ``GML_STUB_CLIENT``. Storage backend comes from ``GML_STORAGE_BACKEND``.
    """
    from pathlib import Path

    holder: dict = {"state": None}
    proxy = _DeferredServerState(holder)

    async def _startup() -> None:
        memory_path = Path(
            os.environ.get("GML_MEMORY_STORE_PATH", "").strip()
            or (Path.home() / ".gml" / "memories.jsonl")
        )
        holder["state"] = await build_default_state(
            embedder=_build_embedder_from_env(),
            memory_path=memory_path,
            enable_sam_llm=os.environ.get("GML_ENABLE_SAM_LLM", "1") != "0",
            default_target_name=os.environ.get("GML_DEFAULT_TARGET", "deepseek"),
            stub_client=os.environ.get("GML_STUB_CLIENT", "0") == "1",
        )
        slog.info(
            event="server_state_ready",
            via="make_app_factory",
            embedder=holder["state"].embedder.version,
        )

    async def _shutdown() -> None:
        from orchestration.storage import close_pg_pool
        await close_pg_pool()

    return build_app(proxy, on_startup=_startup, on_shutdown=_shutdown)
